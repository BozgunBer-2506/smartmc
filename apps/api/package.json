{
  "name": "@smc/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nodemon --watch src --watch ../../packages --ext ts,json --exec \"ts-node src/main.ts\"",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/websockets": "^10.4.0",
    "@smc/connector-sdk": "workspace:*",
    "@smc/database": "workspace:*",
    "@smc/event-model": "workspace:*",
    "@smc/identity": "workspace:*",
    "@smc/shared": "workspace:*",
    "argon2": "^0.41.0",
    "bullmq": "^5.28.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@smc/config": "workspace:*",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
