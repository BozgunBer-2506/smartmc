// A growing subset of docs/DATABASE.md's full schema - implemented as
// later phases actually need more of it, not speculatively ahead of need.
// Phase 1 added the messaging core (Workspace/Provider/Contact/
// ContactIdentity/Conversation/Message/Notification). Phase 2 adds
// Organization, User, UserCredentials, WorkspaceMember, Session, and
// AuditLog for authentication (docs/ROADMAP.md Phase 2, ADR-0014).
// Phase 4 Sprint 2 adds LinkedAccount (docs/DATABASE.md Section 6.5,
// status vocabulary corrected per ADR-0018) and SecretRecord (the interim
// envelope-encrypted secrets store, ADR-0016 - not part of DATABASE.md's
// documented schema, since it's a Sprint 2 implementation detail, not a
// product-domain entity).
// Still deferred: IdentityGraph's confidence-score/merge-suggestion
// tables (Phase 9), RLS, DB role separation (DATABASE.md Section 21) -
// all tracked in docs/reviews/.
// IDs are UUIDv7 (ADR-0007), generated application-side (see
// packages/database/src/ids.ts) rather than via Prisma's @default(uuid()),
// which only generates UUIDv4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The billing/identity root - one per customer (docs/DATABASE.md Section 6.1).
/// Added Phase 2: every registration creates one automatically, per
/// docs/API.md Section 10.1 ("even solo signups get one automatically").
model Organization {
  id        String    @id @db.Uuid
  name      String
  slug      String    @unique
  planTier  String    @default("free") @map("plan_tier")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspaces Workspace[]

  @@map("organizations")
}

model Workspace {
  id             String    @id @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  timezone       String    @default("UTC")
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7, enforced via packages/database/src/soft-delete.ts

  organization  Organization      @relation(fields: [organizationId], references: [id])
  members       WorkspaceMember[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  notifications Notification[]
  linkedAccounts LinkedAccount[]

  @@map("workspaces")
}

/// Global identity, independent of any workspace (docs/DATABASE.md Section 6.3).
/// Auth secrets live in UserCredentials, not here - see that model's comment.
model User {
  id          String    @id @db.Uuid
  email       String    @unique // lower-cased at the application layer for case-insensitivity - see AuthService; docs/DATABASE.md's citext suggestion is deliberately simplified here, recorded in docs/reviews/phase-2-review.md
  displayName String?   @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  credentials UserCredentials?
  memberships WorkspaceMember[]
  sessions    Session[]

  @@map("users")
}

/// Auth secrets, deliberately separate from `users` (docs/DATABASE.md
/// Section 6.3's stated reasoning: reduces the blast radius of an
/// accidental over-fetch on the frequently-joined User row).
/// `passwordHash` is nullable specifically so a future passkey-only or
/// OAuth-only user (ROADMAP.md Phase 2's remaining checklist items) never
/// requires a password row - this is the concrete schema property that
/// makes Passkeys additive later, not a redesign.
model UserCredentials {
  id           String   @id @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  passwordHash String?  @map("password_hash")
  totpSecret   String?  @map("totp_secret") // reserved for 2FA (ROADMAP.md Phase 2 checklist, not implemented yet)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_credentials")
}

/// Which Users belong to which Workspace, with what role (docs/DATABASE.md
/// Section 6.3) - the RBAC foundation (Owner/Admin/Member, ARCHITECTURE.md
/// Section 6 step 4).
model WorkspaceMember {
  id              String    @id @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  role            String    @default("owner") // "owner" | "admin" | "member" - docs/DATABASE.md Section 6.3
  invitedByUserId String?   @map("invited_by_user_id") @db.Uuid
  joinedAt        DateTime  @default(now()) @map("joined_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId], name: "uq_workspace_members_workspace_user")
  @@map("workspace_members")
}

/// Refresh-token session state (docs/DATABASE.md Section 6.20). `familyId`
/// implements the rotation + reuse-detection scheme (ARCHITECTURE.md
/// Section 6, SECURITY.md Section 4.3): presenting an already-rotated
/// token from a family revokes every session in it.
model Session {
  id               String    @id @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  familyId         String    @map("family_id") @db.Uuid
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.Inet
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_sessions_user_id")
  @@index([familyId], name: "idx_sessions_family_id")
  @@map("sessions")
}

/// Append-only audit trail (docs/DATABASE.md Section 6.21). No `updatedAt`/
/// `deletedAt` - application code only ever creates rows here (see
/// AuditLogService), never updates or deletes them. Postgres-role-level
/// enforcement (REVOKE UPDATE, DELETE) is deferred - DATABASE.md Section 21,
/// tracked as an already-deferred gap since the Phase 1 review.
/// No FK relations to Workspace/User: DATABASE.md's cascading rules keep
/// audit history independent of whether its subject still exists.
model AuditLog {
  id             String   @id @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  actorType      String   @map("actor_type") // "user" | "system" | "rule" | "api_key"
  action         String
  resourceType   String?  @map("resource_type")
  resourceId     String?  @map("resource_id") @db.Uuid
  metadata       Json?
  ipAddress      String?  @map("ip_address") @db.Inet
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt], name: "idx_audit_logs_workspace_id_created_at")
  @@index([actorUserId, createdAt], name: "idx_audit_logs_actor_user_id_created_at")
  @@index([resourceType, resourceId], name: "idx_audit_logs_resource_type_resource_id")
  @@map("audit_logs")
}

model Provider {
  id          String @id @db.Uuid
  key         String @unique
  displayName String @map("display_name")

  contactIdentities ContactIdentity[]
  conversations     Conversation[]
  linkedAccounts    LinkedAccount[]

  @@map("providers")
}

/// A Workspace's connection to one Provider account, e.g. "this Telegram
/// bot" (docs/DATABASE.md Section 6.5). `status` uses CONNECTOR_SDK.md
/// Section 2's full 9-state lifecycle vocabulary, not DATABASE.md's
/// original 5-value sketch - see ADR-0018 for why. `credentialsRef` is an
/// opaque pointer into SecretRecord (ADR-0016's interim secrets store) -
/// this model never holds a raw credential itself.
model LinkedAccount {
  id                String    @id @db.Uuid
  workspaceId       String    @map("workspace_id") @db.Uuid
  providerId        String    @map("provider_id") @db.Uuid
  externalAccountId String    @map("external_account_id")
  displayLabel      String?   @map("display_label")
  status            String    @default("registered") // CONNECTOR_SDK.md Section 2 lifecycle states - ADR-0018
  credentialsRef    String    @map("credentials_ref") @db.Uuid // -> SecretRecord.id, never a raw credential - SECURITY.md Section 5, ADR-0016
  webhookSecret     String?   @map("webhook_secret") // inbound webhook verification only - not a provider credential, SECURITY.md Section 5's boundary doesn't apply to this value (see TelegramController)
  syncCursor        String?   @map("sync_cursor") // durable checkpoint (CONNECTOR_SDK.md Section 9) - Telegram's getUpdates offset
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastError         String?   @map("last_error")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  provider      Provider       @relation(fields: [providerId], references: [id])
  conversations Conversation[]

  @@unique([workspaceId, providerId, externalAccountId], name: "uq_linked_accounts_workspace_provider_external")
  @@index([workspaceId], name: "idx_linked_accounts_workspace_id")
  @@index([status], name: "idx_linked_accounts_status")
  @@map("linked_accounts")
}

/// The interim secrets store (ADR-0016) - AES-256-GCM ciphertext, never
/// soft-deleted (deliberately excluded from packages/database/src/soft-delete.ts's
/// SOFT_DELETE_MODELS): SECURITY.md Section 5.2 requires disconnecting a
/// LinkedAccount to unconditionally, irreversibly delete its credential,
/// which a soft-deleted-but-still-decryptable row would not achieve.
model SecretRecord {
  id         String   @id @db.Uuid
  ciphertext Bytes
  iv         Bytes
  authTag    Bytes    @map("auth_tag")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("secret_records")
}

/// A deduplicated real person, independent of channel - IdentityGraph's
/// persistence layer (docs/ARCHITECTURE.md Section 13, docs/DATABASE.md
/// Section 6.6). This Phase 1 version implements exact-match resolution
/// only (docs/ROADMAP.md Phase 3 scope) - confidence scoring and the
/// merge-suggestion queue are Phase 9 additions.
model Contact {
  id          String    @id @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  displayName String    @map("display_name")
  isVip       Boolean   @default(false) @map("is_vip")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspace  Workspace         @relation(fields: [workspaceId], references: [id])
  identities ContactIdentity[]
  messages   Message[]

  @@map("contacts")
}

model ContactIdentity {
  id          String   @id @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  providerId  String   @map("provider_id") @db.Uuid
  externalId  String   @map("external_id")
  handle      String?
  matchType   String   @default("exact") @map("match_type") // "exact" | "confirmed_manual" - docs/DATABASE.md Section 6.6
  createdAt   DateTime @default(now()) @map("created_at")

  contact  Contact  @relation(fields: [contactId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, externalId, workspaceId], name: "uq_contact_identities_provider_external")
  @@map("contact_identities")
}

model Conversation {
  id              String   @id @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  providerId      String   @map("provider_id") @db.Uuid
  linkedAccountId String?  @map("linked_account_id") @db.Uuid // nullable - Mock Connector conversations (Phase 1-3) have none; real connectors (Phase 4 Sprint 2+) always set it
  externalId      String   @map("external_id")
  title           String?
  lastMessageAt DateTime?  @map("last_message_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  deletedAt     DateTime?  @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspace     Workspace      @relation(fields: [workspaceId], references: [id])
  provider      Provider       @relation(fields: [providerId], references: [id])
  linkedAccount LinkedAccount? @relation(fields: [linkedAccountId], references: [id])
  messages      Message[]

  @@unique([providerId, externalId, workspaceId], name: "uq_conversations_provider_external")
  @@map("conversations")
}

model Message {
  id               String   @id @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  conversationId   String   @map("conversation_id") @db.Uuid
  externalId       String   @map("external_id")
  senderContactId  String?  @map("sender_contact_id") @db.Uuid
  direction        String    // "inbound" | "outbound" - docs/DATABASE.md Section 6.8
  bodyText         String    @map("body_text")
  receivedAt       DateTime  @map("received_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at") // soft delete - docs/DATABASE.md Section 7

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  conversation Conversation  @relation(fields: [conversationId], references: [id])
  sender       Contact?      @relation(fields: [senderContactId], references: [id])
  notifications Notification[]

  @@unique([conversationId, externalId], name: "uq_messages_conversation_external")
  @@map("messages")
}

model Notification {
  id          String   @id @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  messageId   String?  @map("message_id") @db.Uuid
  type        String   @default("message") // "message" | "reminder" | "digest" | "system" - docs/DATABASE.md Section 6.14
  title       String
  body        String
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  message   Message?  @relation(fields: [messageId], references: [id])

  @@map("notifications")
}
