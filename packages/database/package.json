{
  "name": "@smc/database",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@smc/config": "workspace:*",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5.6.0"
  }
}
